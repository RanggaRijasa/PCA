APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Local model settings.
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma3:1b
EMBED_MODEL=bge-m3
OLLAMA_TIMEOUT_SECONDS=120

# Local storage.
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=company_documents
SQLITE_PATH=./data/app.db
RAW_DOCS_PATH=./data/raw
METADATA_CSV_PATH=./data/metadata/document_metadata.csv
PROCESSED_DOCS_PATH=./data/processed
BACKUP_PATH=./data/backups
MAX_UPLOAD_SIZE_MB=25
CHUNK_TARGET_TOKENS=600
CHUNK_OVERLAP_TOKENS=80
CHUNK_MAX_TOKENS=1000

# Retrieval and grounded-answer settings.
DEFAULT_TOP_K=20
RERANK_TOP_K=5
MAX_CONTEXT_CHUNKS=6
RETRIEVAL_MIN_SCORE=0.30
RETRIEVAL_MIN_LEXICAL_OVERLAP=0.08
RETRIEVAL_MIN_VECTOR_SCORE=0.60
CONTEXT_SCORE_MARGIN=0.12
AUDIT_STORE_ANSWER_TEXT=false

# Local authentication. Change this before initializing a non-test database.
SEED_USER_PASSWORD=ChangeMe-Local-Only-123!
SESSION_COOKIE_NAME=pca_session
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false
EVAL_REPORTS_PATH=./eval/reports

# Frontend settings. Copy relevant VITE_* values into frontend/.env.local.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_USE_LOCAL_MOCKS=false
